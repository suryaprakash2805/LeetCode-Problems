class Solution {
    public Node copyRandomList(Node head) { 
        Node dummy = new Node(-1);
        dummy.next = head;

        Node cur = head;
        while(cur != null){
            Node copy = new Node(cur.val);
            copy.next = cur.next;
            cur.next = copy;
            cur = copy.next;
        }

        cur = head;
        while(cur != null){
           Node copy = cur.next;

           if(cur.random != null){
            copy.random = cur.random.next;
           }
           else{
             copy.random = null;
           }
          
          cur = cur.next.next;
        }

        Node temp = dummy;
        cur = head;
        while(cur != null){
           temp.next = cur.next;
           temp = temp.next;
           cur.next = cur.next.next;
           cur = cur.next;
        }

        return dummy.next;
    }
}
