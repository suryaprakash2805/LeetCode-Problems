class Solution {
    public List<List<Integer>> combinationSum3(int k, int n) {
         if(k>n) return new ArrayList<>();
         List<List<Integer>> result = new ArrayList<>();
         findCombinations(k,n,1,new ArrayList<>(),result);
         return result;
    }

    public void findCombinations(int k, int n, int index, List<Integer> temp, 
                                 List<List<Integer>> result){
           if(n == 0 && temp.size() == k){
             result.add(new ArrayList<>(temp));
             return;
           }
           if(n<0 || temp.size()>k) return;
           for(int i=index;i<10;i++){
              if(i>n) break;
              temp.add(i);
              findCombinations(k,n-i,i+1,temp,result);
              temp.remove(temp.size()-1);
           }
    }
}
