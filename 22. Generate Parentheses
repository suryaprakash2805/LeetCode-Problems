class Solution {
    public List<String> generateParenthesis(int n) {
        return generateValidParenthesis(n, new ArrayList<>(), "", 0, 0);
    }

  public List<String> generateValidParenthesis(
    int n, List<String> result, String str, int open, int close
    ){

       if(str.length() == n*2){
          result.add(str);
          return result;
       }

       if(open < n){
          generateValidParenthesis(n, result, str+"(", open+1, close);
       }

       if(close < open){
          generateValidParenthesis(n, result, str+")", open, close+1);
       }

      return result;
  }
}
