class Solution {
    public List<List<Integer>> subsetsWithDup(int[] nums) {
        Arrays.sort(nums);
        List<List<Integer>> result = new ArrayList<>();
        findSubsetsWithDup(nums,0,new ArrayList<>(),result);
        return result;
    }

    public void findSubsetsWithDup(int nums[], int index, List<Integer> temp, 
                                   List<List<Integer>> result){
         if(index==nums.length){
            result.add(new ArrayList<>(temp));
            return;
         }
         temp.add(nums[index]);
         findSubsetsWithDup(nums, index+1, temp, result);
         temp.remove(temp.size()-1);
         int next = index+1;
         while(next<nums.length && nums[next]==nums[index]) next++;
         findSubsetsWithDup(nums, next, temp, result);
    }
}
